# NeuroScan AI — Local Development Environment
# ─────────────────────────────────────────────
# For RAILWAY DEPLOYMENT: Set these same vars in
#   Railway dashboard → your service → Variables tab
# DO NOT rely on this file on Railway — it is not uploaded.

# Groq API (clinical AI analysis)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# App
APP_NAME=NeuroScan AI
APP_VERSION=2.1.0
HOST=0.0.0.0
PORT=8000

# Model hyperparameters
FUSION_BIAS=-0.312
FUSION_WEIGHT=3.847
FUSION_W_IMG=0.55
FUSION_W_AUD=0.45
